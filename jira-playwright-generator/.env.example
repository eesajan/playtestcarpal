# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_JQL=project = QA AND issuetype = "Test Case" AND status != Done

# App under test
# Local sample app used by npm run generate:sample + npm run test:e2e.
# Replace with the real app URL when running Jira-generated tests.
BASE_APP_URL=http://127.0.0.1:3000

# Optional: comma-separated Jira fields to fetch
JIRA_FIELDS=summary,description

# AI Agents (framework-architect --ai, automation-generator, recorder-enhancer)
ANTHROPIC_API_KEY=your-anthropic-api-key
