# CarPal QA
CARPAL_BASE_URL=https://qa.carpal.com
CARPAL_USERNAME=your-username
CARPAL_PASSWORD=your-password

# Jira integration (for npm run generate)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_JQL=project = QA AND issuetype = "Test Case" AND status != Done
JIRA_FIELDS=summary,description

# Local sample app (for npm run test:e2e without a real CarPal instance)
BASE_APP_URL=http://127.0.0.1:3000

# AI Agents (required for agent:architect --ai, agent:generate, agent:enhance)
ANTHROPIC_API_KEY=your-anthropic-api-key
