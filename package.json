{
  "name": "playtestcarpal",
  "version": "1.0.0",
  "description": "Playwright TypeScript automation framework for CarPal QA",
  "type": "module",
  "scripts": {
    "generate": "tsx tools/index.ts",
    "generate:sample": "tsx tools/sample-run.ts",
    "sample-app": "tsx tools/sample-app-server.ts",
    "test:e2e": "playwright test tests/",
    "test:e2e:headed": "playwright test tests/ --headed",
    "test:e2e:ui": "playwright test tests/ --ui",
    "test:carpal": "playwright test --config playwright.config.carpal.ts",
    "test:carpal:headed": "playwright test --config playwright.config.carpal.ts --headed",
    "report": "playwright show-report",
    "agent:architect": "tsx tools/agents/framework-architect.ts",
    "agent:architect:ai": "tsx tools/agents/framework-architect.ts --ai",
    "agent:generate": "tsx tools/agents/automation-generator.ts",
    "agent:enhance": "tsx tools/agents/recorder-enhancer.ts",
    "recorder": "node scripts/open-recorder.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@playwright/test": "latest",
    "axios": "latest",
    "dotenv": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "@types/node": "latest"
  }
}
